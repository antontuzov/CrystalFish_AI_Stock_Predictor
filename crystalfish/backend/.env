# CrystalFish Environment Configuration

# App
DEBUG=false
SECRET_KEY=your-secret-key-change-in-production

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/crystalfish
DATABASE_URL_SYNC=postgresql://postgres:postgres@postgres:5432/crystalfish

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_BROKER_URL=redis://redis:6379/1

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenRouter (get free API key at openrouter.ai)
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=""

# External APIs (optional)
COINGECKO_API_KEY=

# CORS
FRONTEND_URL=http://localhost:5173